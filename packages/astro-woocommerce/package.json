{
  "name": "astro-woocommerce",
  "version": "1.1.0",
  "description": "Type-safe WooCommerce integration for Astro. Fetch products, categories, and manage cart state with full TypeScript support. Perfect for building fast, headless e-commerce sites with Astro.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astro",
    "astro-integration",
    "withastro",
    "woocommerce",
    "wordpress",
    "headless",
    "e-commerce",
    "commerce",
    "typescript",
    "api",
    "rest",
    "tooling",
    "utils",
    "utility"
  ],
  "homepage": "https://github.com/Ardesh1r/astro-woocommerce.git",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ardesh1r/astro-woocommerce.git"
  },
  "bugs": "https://github.com/Ardesh1r/astro-woocommerce/issues",
  "author": "Ardeshir Shojaei",
  "license": "MIT",
  "peerDependencies": {
    "astro": "^4.0.0"
  },
  "devDependencies": {
    "astro": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  }
}
